# PostgreSQL
POSTGRES_PASSWORD=changeme

# Service DBs (Docker internal hostnames)
AUTH_DATABASE_URL=postgresql+asyncpg://kms:kms@db_auth:5432/kms_auth
CONTENT_DATABASE_URL=postgresql+asyncpg://kms:kms@db_content:5432/kms_content
ASSESSMENT_DATABASE_URL=postgresql+asyncpg://kms:kms@db_assessment:5432/kms_assessment

# JWT (auth-service only)
SECRET_KEY=super-secret-key-change-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# TLS / Let's Encrypt
DOMAIN=localhost
EMAIL=admin@example.com

# API Gateway URL (for frontend proxy)
# Default: http://api-gateway (Docker internal)
# For separate server: http://gateway-server-ip or https://api.example.com
API_GATEWAY_URL=http://api-gateway

# PostgreSQL (one password for all databases)
POSTGRES_PASSWORD=changeme

# JWT (auth-service only)
SECRET_KEY=super-secret-key-change-in-prod
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# TLS / Let's Encrypt
# Replace with your real domain for production
DOMAIN=localhost
# Email for Let's Encrypt notifications (required for production)
EMAIL=admin@example.com

# API Gateway URL (for frontend proxy)
# Default: http://api-gateway (Docker internal)
# For separate server: http://gateway-server-ip or https://api.example.com
API_GATEWAY_URL=http://api-gateway
